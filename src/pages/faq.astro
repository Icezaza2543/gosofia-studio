---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FAQComponent from '../components/FAQ.astro';
---

<BaseLayout
  title="คำถามที่พบบ่อย"
  description="คำถามที่พบบ่อยเกี่ยวกับการจ้างวาด Commission กับ Gosofia"
>
  <SiteHeader />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-ink">❓ คำถามที่พบบ่อย / FAQ</h1>
      <p class="text-muted mt-2">คำตอบจากคุณโกเองงับ~</p>
    </div>

    <FAQComponent />

    <div class="mt-10 p-6 rounded-2xl bg-secondary-light border border-secondary-dark/20 text-center">
      <p class="text-base font-semibold text-ink mb-3">ยังมีคำถามอื่นอีกมั้ย?</p>
      <p class="text-sm text-muted mb-4">ทักมาคุยกันได้เลย ยินดีตอบทุกคำถามงับ 💬</p>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white font-bold text-sm hover:bg-primary-light transition-colors"
      >
        ติดต่อนักวาด
      </a>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

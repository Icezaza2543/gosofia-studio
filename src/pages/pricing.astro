---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { workTypes, complexityOptions, backgroundOptions, rushOptions, ADULT_RATE, LIVE2D_RATE, COMMERCIAL_MULTIPLIER, SOURCE_FILE_PRICE, SOURCE_FILE_PRICE_USD, RIGGING_BASE_PRICE, RIGGING_BASE_PRICE_USD, EXTRA_PARTS_PRICE, EXTRA_PARTS_PRICE_USD, MINIMUM_DEPOSIT, MINIMUM_DEPOSIT_USD, DOUJIN_PAGE_PRICE_THB, DOUJIN_PAGE_PRICE_USD } from '../data/pricing';
import { formatMoney } from '../lib/formatMoney';
---

<BaseLayout
  title="เรตราคา Commission"
  description="ตารางราคา Commission ของ Gosofia — Head Shot, Half Body, Full Body, Chibi, Vtuber Model, Merch"
>
  <SiteHeader />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-ink" data-i18n="pricing.page.title">💰 เรตราคา Commission</h1>
      <p class="text-muted mt-2" data-i18n="pricing.page.desc">ราคาเริ่มต้นตามประเภทงาน — ราคาจริงอาจปรับตามดีเทลและ scope จริง</p>
    </div>

    <!-- Work Types Table -->
    <div class="rounded-2xl border border-line bg-white shadow-lg overflow-hidden mb-8">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-secondary-light border-b border-line">
              <th class="px-5 py-3 text-left font-bold text-primary" data-i18n="pricing.table.type">ประเภทงาน</th>
              <th class="px-5 py-3 text-right font-bold text-primary">B/W</th>
              <th class="px-5 py-3 text-right font-bold text-primary">Full Color</th>
              <th class="px-5 py-3 text-right font-bold text-primary" data-i18n="pricing.table.days">ระยะเวลา (วัน)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            {workTypes.map((wt) => (
              <tr class="hover:bg-surface transition-colors">
                <td class="px-5 py-3">
                  <div class="font-semibold text-ink" data-i18n={`pricing.wt.${wt.id}.en`}>{wt.label}</div>
                  <div class="text-xs text-muted" data-i18n={`pricing.wt.${wt.id}.th`}>{wt.labelTh}</div>
                </td>
                <td class="px-5 py-3 text-right font-semibold text-ink">
                  {wt.id === 'doujin' ? (
                    <span
                      data-money-thb={DOUJIN_PAGE_PRICE_THB}
                      data-money-usd={DOUJIN_PAGE_PRICE_USD}
                      data-money-suffix-th="/หน้า (ขาวดำ)"
                      data-money-suffix-en="/page (B/W)"
                    >
                      {formatMoney(DOUJIN_PAGE_PRICE_THB, 'THB')}/หน้า (ขาวดำ)
                    </span>
                  ) : (wt.bw !== null ? <span data-money-thb={wt.bw} data-money-usd={wt.bwUsd}>{formatMoney(wt.bw, 'THB')}</span> : '—')}
                </td>
                <td class="px-5 py-3 text-right font-semibold text-primary">
                  {wt.id === 'doujin'
                    ? <span data-i18n="pricing.doujin.cover">ตามสเกลหน้าปก</span>
                    : (wt.color !== null ? <span data-money-thb={wt.color} data-money-usd={wt.colorUsd}>{formatMoney(wt.color, 'THB')}</span> : '—')}
                </td>
                <td class="px-5 py-3 text-right text-muted">
                  {wt.estimatedDays[0]}–{wt.estimatedDays[1]}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Add-ons Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      <!-- Complexity -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.complexity">🎯 ดีเทลตัวละคร</h3>
        <ul class="space-y-2">
          {complexityOptions.map((opt) => (
            <li class="flex justify-between text-sm">
              <span class="text-muted" data-i18n={`pricing.complexity.${opt.id}`}>{opt.labelTh}</span>
              <span class="font-semibold text-ink">{opt.surcharge > 0 ? <span data-money-thb={opt.surcharge} data-money-usd={opt.surchargeUsd} data-money-prefix="+">{`+${formatMoney(opt.surcharge, 'THB')}`}</span> : <span data-i18n="pricing.nocharge">ไม่คิดเพิ่ม</span>}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Background -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.bg">🖼️ ฉาก</h3>
        <ul class="space-y-2">
          {backgroundOptions.map((opt) => (
            <li class="flex justify-between text-sm">
              <span class="text-muted" data-i18n={`pricing.bg.${opt.id}`}>{opt.labelTh}</span>
              <span class="font-semibold text-ink">
                {opt.surcharge === null ? <span data-i18n="pricing.notaccept">ไม่รับ</span> : opt.surcharge > 0 ? <span data-money-thb={opt.surcharge} data-money-usd={opt.surchargeUsd} data-money-prefix="+">{`+${formatMoney(opt.surcharge, 'THB')}`}</span> : <span data-i18n="pricing.nocharge">ไม่คิดเพิ่ม</span>}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Rush -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.rush">⚡ งานเร่ง</h3>
        <ul class="space-y-2">
          {rushOptions.map((opt) => (
            <li class="flex justify-between text-sm">
              <span class="text-muted" data-i18n={`pricing.rush.${opt.id}`}>{opt.labelTh}</span>
              <span class="font-semibold text-ink">
                {opt.surcharge === null ? <span data-i18n="pricing.notaccept">ไม่รับ</span> : opt.surcharge > 0 ? <span data-money-thb={opt.surcharge} data-money-usd={opt.surchargeUsd} data-money-prefix="+">{`+${formatMoney(opt.surcharge, 'THB')}`}</span> : <span data-i18n="pricing.nocharge">ไม่คิดเพิ่ม</span>}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Multipliers -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.multipliers">📊 ตัวคูณ</h3>
        <ul class="space-y-2">
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.multipliers.commercial">เชิงพาณิชย์</span>
            <span class="font-semibold text-ink">×{COMMERCIAL_MULTIPLIER}</span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.multipliers.adult">เนื้อหาผู้ใหญ่</span>
            <span class="font-semibold text-ink">+{ADULT_RATE * 100}%</span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.multipliers.live2d">แยกพาร์ต Live2D</span>
            <span class="font-semibold text-ink">+{LIVE2D_RATE * 100}%</span>
          </li>
        </ul>
      </div>

      <!-- Flat Add-ons -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.extras">🔧 ตัวเลือกเสริม</h3>
        <ul class="space-y-2">
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.extras.psd">ไฟล์ PSD (Vtuber)</span>
            <span class="font-semibold text-ink" data-money-thb={SOURCE_FILE_PRICE} data-money-usd={SOURCE_FILE_PRICE_USD}>{formatMoney(SOURCE_FILE_PRICE, 'THB')}</span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="calc.addons.rigging">Rigging</span>
            <span class="font-semibold text-ink"><span data-i18n="pricing.startat">เริ่มที่</span> <span data-money-thb={RIGGING_BASE_PRICE} data-money-usd={RIGGING_BASE_PRICE_USD}>{formatMoney(RIGGING_BASE_PRICE, 'THB')}</span></span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.extras.parts">ชิ้นส่วนเพิ่ม</span>
            <span class="font-semibold text-ink"><span data-i18n="pricing.startat">เริ่มที่</span> <span data-money-thb={EXTRA_PARTS_PRICE} data-money-usd={EXTRA_PARTS_PRICE_USD} data-money-suffix-th="/ชิ้น" data-money-suffix-en="/part">{formatMoney(EXTRA_PARTS_PRICE, 'THB')}/ชิ้น</span></span>
          </li>
        </ul>
      </div>

      <!-- Deposit -->
      <div class="rounded-xl border border-line bg-white p-5">
        <h3 class="text-base font-bold text-ink mb-3" data-i18n="pricing.addons.payment">💳 การชำระเงิน</h3>
        <ul class="space-y-2">
          <li class="flex justify-between text-sm">
            <span class="text-muted" data-i18n="pricing.payment.deposit">มัดจำขั้นต่ำ</span>
            <span class="font-semibold text-ink" data-money-thb={MINIMUM_DEPOSIT} data-money-usd={MINIMUM_DEPOSIT_USD}>{formatMoney(MINIMUM_DEPOSIT, 'THB')}</span>
          </li>
          <li class="text-sm text-muted" data-i18n="pricing.payment.installments">ผ่อนได้สูงสุด 3 งวด</li>
          <li class="text-sm text-muted" data-i18n="pricing.payment.methods">รับชำระผ่าน Stripe, Wise, Ko-fi</li>
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="/calculator/"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-primary text-white font-bold text-lg hover:bg-primary-light transition-colors shadow-lg shadow-primary/20"
        data-i18n="pricing.cta"
      >
        🧮 ลองคำนวณราคาเลย
      </a>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  import { formatMoney } from '../lib/formatMoney';
  import { currencyForLanguage, type Currency, type PricingLanguage } from '../lib/currency';

  function getPricingLanguage(): PricingLanguage {
    return localStorage.getItem('gosofia-lang') === 'en' || document.documentElement.lang === 'en'
      ? 'en'
      : 'th';
  }

  function getPricingCurrency(): Currency {
    return currencyForLanguage(getPricingLanguage());
  }

  function renderPricingMoney() {
    const currency = getPricingCurrency();
    document.querySelectorAll<HTMLElement>('[data-money-thb]').forEach((el) => {
      const rawAmount = currency === 'USD' ? el.dataset.moneyUsd : el.dataset.moneyThb;
      const amount = Number(rawAmount);
      if (!Number.isFinite(amount)) return;

      const prefix = el.dataset.moneyPrefix || '';
      const suffix = currency === 'USD'
        ? (el.dataset.moneySuffixEn || '')
        : (el.dataset.moneySuffixTh || '');
      el.textContent = `${prefix}${formatMoney(amount, currency)}${suffix}`;
    });
  }

  window.addEventListener('languageChanged', renderPricingMoney);
  renderPricingMoney();
</script>

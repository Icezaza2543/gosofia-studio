---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import AgeGateModal from '../components/AgeGateModal.astro';
import { PIXIV_ARCHIVE_URL } from '../data/portfolio';
---

<BaseLayout
  title="ผลงาน"
  description="ผลงานวาดของ Gosofia — Character Art, Vtuber Model, Merch Illustration และอื่น ๆ"
>
  <SiteHeader />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold text-ink" data-i18n="portfolio.title">🎨 ผลงาน / Portfolio</h1>
        <p class="text-muted mt-2" data-i18n="portfolio.desc">เลือกหมวดหมู่เพื่อกรองผลงาน</p>
      </div>
      <a 
        href={PIXIV_ARCHIVE_URL} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white font-bold hover:bg-primary-light transition-colors shadow-sm self-start sm:self-auto"
        data-i18n="portfolio.pixiv.cta"
      >
        ผลงานทั้งหมดใน Pixiv
      </a>
    </div>

    <PortfolioGrid />
  </main>

  <AgeGateModal />
  <SiteFooter />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CommissionCalculator from '../components/CommissionCalculator.astro';
import PriceBreakdown from '../components/PriceBreakdown.astro';
---

<BaseLayout
  title="คำนวณราคา Commission"
  description="คำนวณราคา Commission เบื้องต้น เลือกประเภทงาน ดีเทล ฉาก และตัวเลือกเสริมต่าง ๆ พร้อมสร้างบรีฟอัตโนมัติ"
>
  <SiteHeader />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-ink" data-i18n="calc.page.title">🧮 คำนวณราคา Commission</h1>
      <p class="text-muted mt-2" data-i18n="calc.page.desc">ประเมินราคาเบื้องต้น — เลือกตัวเลือกแล้วคัดลอกบรีฟส่งมาคุยได้เลย</p>
    </div>

    <div class="grid lg:grid-cols-[1.4fr_0.8fr] gap-6 items-start">
      <CommissionCalculator />
      <PriceBreakdown />
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  // ─── Calculator Client-Side Logic ───
  // Imports the pure calculation function and wires it to the UI

  import { calculatePrice, type CalculatorInput, type PriceLanguage } from '../lib/calculatePrice';
  import { buildBrief } from '../lib/buildBrief';
  import { formatMoney } from '../lib/formatMoney';
  import { i18n, type Language } from '../data/i18n';
  import { workTypes } from '../data/pricing';

  // ─── DOM references ───
  const els = {
    workType: document.getElementById('calc-work-type') as HTMLSelectElement,
    doujinFields: document.getElementById('doujin-fields') as HTMLElement,
    doujinPages: document.getElementById('calc-doujin-pages') as HTMLInputElement,
    wantCover: document.getElementById('calc-want-cover') as HTMLInputElement,
    coverScaleField: document.getElementById('cover-scale-field') as HTMLElement,
    coverScale: document.getElementById('calc-cover-scale') as HTMLSelectElement,
    colorField: document.getElementById('color-mode-field') as HTMLElement,
    characters: document.getElementById('calc-characters') as HTMLInputElement,
    complexity: document.getElementById('calc-complexity') as HTMLSelectElement,
    background: document.getElementById('calc-background') as HTMLSelectElement,
    rush: document.getElementById('calc-rush') as HTMLSelectElement,
    commercial: document.getElementById('calc-commercial') as HTMLInputElement,
    live2d: document.getElementById('calc-live2d') as HTMLInputElement,
    adult: document.getElementById('calc-adult') as HTMLInputElement,
    adultConfirm: document.getElementById('calc-adult-confirm') as HTMLInputElement,
    adultConfirmRow: document.getElementById('adult-confirm-row') as HTMLElement,
    rigging: document.getElementById('calc-rigging') as HTMLInputElement,
    sourceFile: document.getElementById('calc-source-file') as HTMLInputElement,
    extraParts: document.getElementById('calc-extra-parts') as HTMLInputElement,
    deposit: document.getElementById('calc-deposit') as HTMLInputElement,
    notes: document.getElementById('calc-notes') as HTMLTextAreaElement,
    projectTitle: document.getElementById('calc-project-title') as HTMLInputElement,
    clientName: document.getElementById('calc-client-name') as HTMLInputElement,
    riggingNote: document.getElementById('calc-rigging-note') as HTMLElement,
    sourceFileNote: document.getElementById('calc-source-file-note') as HTMLElement,
    extraPartsNote: document.getElementById('calc-extra-parts-note') as HTMLElement,
    depositNote: document.getElementById('calc-deposit-note') as HTMLElement,
    // Output
    total: document.getElementById('calc-total') as HTMLElement,
    range: document.getElementById('calc-range') as HTMLElement,
    breakdown: document.getElementById('calc-breakdown') as HTMLElement,
    briefPreview: document.getElementById('brief-preview') as HTMLElement,
    copyBtn: document.getElementById('copy-brief-btn') as HTMLButtonElement,
    resetBtn: document.getElementById('reset-calc-btn') as HTMLButtonElement,
    policyGuard: document.getElementById('policy-guard') as HTMLElement,
    vtuberOptions: document.getElementById('vtuber-options') as HTMLElement,
  };

  function getSelectedColor(): 'bw' | 'color' {
    const checked = document.querySelector<HTMLInputElement>('input[name="calc-color"]:checked');
    return (checked?.value === 'bw') ? 'bw' : 'color';
  }

  function getLanguage(): PriceLanguage {
    const savedLang = localStorage.getItem('gosofia-lang') as Language | null;
    const docLang = document.documentElement.lang as Language;
    return savedLang === 'en' || docLang === 'en' ? 'en' : 'th';
  }

  function getText(lang: PriceLanguage, key: keyof typeof i18n.th): string {
    return i18n[lang][key] ?? i18n.th[key];
  }

  function updateLocalizedOptions(lang: PriceLanguage) {
    [els.complexity, els.background, els.rush].forEach((select) => {
      select.querySelectorAll<HTMLOptionElement>('option').forEach((option) => {
        const label = option.dataset[lang === 'en' ? 'labelEn' : 'labelTh'] || option.textContent || '';
        const surcharge = Number(option.dataset[lang === 'en' ? 'surchargeUsd' : 'surcharge']) || 0;
        option.textContent = surcharge > 0 ? `${label} (+${formatMoney(surcharge, lang)})` : label;
      });
    });
  }

  function updateLocalizedPriceHints(lang: PriceLanguage) {
    const riggingAmount = Number(els.riggingNote.dataset[lang === 'en' ? 'amountUsd' : 'amount']) || 0;
    const sourceFileAmount = Number(els.sourceFileNote.dataset[lang === 'en' ? 'amountUsd' : 'amount']) || 0;
    const extraPartsAmount = Number(els.extraPartsNote.dataset[lang === 'en' ? 'amountUsd' : 'amount']) || 0;

    els.riggingNote.textContent = `(+${formatMoney(riggingAmount, lang)})`;
    els.sourceFileNote.textContent = lang === 'en'
      ? `(Vtuber only +${formatMoney(sourceFileAmount, lang)})`
      : `(Vtuber เท่านั้น +${formatMoney(sourceFileAmount, lang)})`;
    els.extraPartsNote.textContent = lang === 'en'
      ? `(+${formatMoney(extraPartsAmount, lang)}/part)`
      : `(+${formatMoney(extraPartsAmount, lang)}/ชิ้น)`;
    els.depositNote.textContent = lang === 'en'
      ? `Minimum ${formatMoney(10, lang)}`
      : `ขั้นต่ำ ${formatMoney(300, lang)}`;
  }

  function syncDepositInputCurrency(lang: PriceLanguage) {
    const currentCurrency = (els.deposit.dataset.currency as PriceLanguage | undefined) || 'th';
    els.deposit.min = lang === 'en' ? '10' : '300';
    els.deposit.step = lang === 'en' ? '1' : '100';

    if (currentCurrency === lang) return;

    // Use a fixed rough conversion just for UI convenience when toggling language
    const UI_CONVERSION_RATE = 32.5;
    const currentValue = Number(els.deposit.value) || 0;
    const currentThbValue = currentCurrency === 'en' ? currentValue * UI_CONVERSION_RATE : currentValue;
    
    let newValue;
    if (lang === 'en') {
      newValue = Math.max(10, Math.round(currentThbValue / UI_CONVERSION_RATE));
    } else {
      newValue = Math.max(300, Math.round(currentThbValue));
    }
    
    els.deposit.value = String(newValue);
    els.deposit.dataset.currency = lang;
  }

  function getInput(lang: PriceLanguage): CalculatorInput {
    const minD = lang === 'en' ? 10 : 300;
    const depositAmount = Number(els.deposit.value) || minD;

    return {
      workTypeId: els.workType.value,
      colorMode: getSelectedColor(),
      characterCount: Number(els.characters.value) || 1,
      complexityId: els.complexity.value,
      backgroundId: els.background.value,
      isCommercial: els.commercial.checked,
      isAdult: els.adult.checked,
      adultConfirmed: els.adultConfirm.checked,
      isLive2D: els.live2d.checked,
      rushId: els.rush.value,
      wantSourceFile: els.sourceFile.checked,
      wantRigging: els.rigging.checked,
      extraPartsCount: Number(els.extraParts.value) || 0,
      depositAmount: lang === 'en' ? usdToThb(depositAmount) : depositAmount,
      doujinPages: Number(els.doujinPages.value) || 1,
      wantCover: els.wantCover.checked,
      coverScaleId: els.coverScale.value,
    };
  }

  function render() {
    const lang = getLanguage();
    const text = i18n[lang];
    updateLocalizedOptions(lang);
    updateLocalizedPriceHints(lang);
    syncDepositInputCurrency(lang);
    const input = getInput(lang);
    const result = calculatePrice(input, lang);
    const wt = workTypes.find(w => w.id === input.workTypeId);

    // Toggle Doujin fields
    const isDoujin = input.workTypeId === 'doujin';
    if (isDoujin) {
      els.doujinFields.classList.remove('hidden');
      if (input.wantCover) {
        els.coverScaleField.classList.remove('hidden');
        els.coverScaleField.classList.add('grid');
      } else {
        els.coverScaleField.classList.add('hidden');
        els.coverScaleField.classList.remove('grid');
      }
    } else {
      els.doujinFields.classList.add('hidden');
    }

    // Toggle color mode visibility
    // Hide color mode if the worktype has no color choice, OR if it's a doujin with NO cover.
    // If doujin with cover, the color mode applies to the cover.
    const isCoverSelected = isDoujin && input.wantCover;
    const activeWorkType = isCoverSelected ? workTypes.find(w => w.id === input.coverScaleId) : wt;
    
    if ((activeWorkType && !activeWorkType.hasColorChoice) || (isDoujin && !input.wantCover)) {
      els.colorField.style.display = 'none';
    } else {
      els.colorField.style.display = '';
    }

    // Toggle adult confirm row
    if (input.isAdult) {
      els.adultConfirmRow.classList.remove('hidden');
      els.adultConfirmRow.classList.add('flex');
    } else {
      els.adultConfirmRow.classList.add('hidden');
      els.adultConfirmRow.classList.remove('flex');
      els.adultConfirm.checked = false;
    }

    // Disable live2d for vtuber and doujin
    if (wt?.id === 'vtuber' || isDoujin) {
      els.live2d.checked = false;
      els.live2d.disabled = true;
    } else {
      els.live2d.disabled = false;
    }

    // Toggle source file availability
    if (wt?.id !== 'vtuber') {
      els.sourceFile.checked = false;
      els.sourceFile.disabled = true;
    } else {
      els.sourceFile.disabled = false;
    }
    
    // Disable rigging/extra parts for non-vtuber
    if (wt?.id !== 'vtuber') {
      els.rigging.checked = false;
      els.rigging.disabled = true;
      els.extraParts.value = '0';
      els.extraParts.disabled = true;
    } else {
      els.rigging.disabled = false;
      els.extraParts.disabled = false;
    }

    // Update total
    els.total.textContent = formatMoney(result.total, lang);
    els.range.textContent = `${formatMoney(result.low, lang)} – ${formatMoney(result.high, lang)} ${text['price.range.afterBrief']}`;

    // Update breakdown
    els.breakdown.innerHTML = result.breakdown
      .map(item => `<li class="flex justify-between gap-3 py-2.5 text-sm"><span class="text-muted">${item.label}</span><strong class="text-ink whitespace-nowrap">${formatMoney(item.amount, lang)}</strong></li>`)
      .join('');

    // Policy guard
    const blockedByPolicy = input.isAdult && !input.adultConfirmed;
    els.copyBtn.disabled = blockedByPolicy;

    if (blockedByPolicy) {
      els.policyGuard.className = 'mt-3 p-3 rounded-xl border border-amber-200 bg-amber-50 text-sm text-amber-800 leading-relaxed';
      els.policyGuard.textContent = text['price.policy.adult'];
    } else {
      els.policyGuard.className = 'mt-3 p-3 rounded-xl border border-green-200 bg-green-50 text-sm text-green-800 leading-relaxed';
      els.policyGuard.textContent = text['price.policy.normal'];
    }

    // Build brief
    const brief = buildBrief(
      {
        projectTitle: els.projectTitle.value,
        clientName: els.clientName.value,
        notes: els.notes.value,
        isAdult: input.isAdult,
        adultConfirmed: input.adultConfirmed,
      },
      result,
      lang
    );
    els.briefPreview.textContent = brief || text['price.policy.adultBrief'];
  }

  // ─── Event listeners ───
  document.querySelectorAll<HTMLElement>('#calc-work-type, #calc-doujin-pages, #calc-want-cover, #calc-cover-scale, #calc-characters, #calc-complexity, #calc-background, #calc-rush, #calc-commercial, #calc-live2d, #calc-adult, #calc-adult-confirm, #calc-rigging, #calc-source-file, #calc-extra-parts, #calc-deposit, #calc-notes, #calc-project-title, #calc-client-name').forEach(el => {
    el.addEventListener('input', render);
    el.addEventListener('change', render);
  });

  document.querySelectorAll<HTMLInputElement>('input[name="calc-color"]').forEach(el => {
    el.addEventListener('change', render);
  });

  // Copy brief
  els.copyBtn.addEventListener('click', async () => {
    if (els.copyBtn.disabled) return;
    const text = els.briefPreview.textContent || '';
    try {
      await navigator.clipboard.writeText(text);
      els.copyBtn.textContent = getText(getLanguage(), 'price.btn.copied');
      setTimeout(() => { els.copyBtn.textContent = getText(getLanguage(), 'price.btn.copy'); }, 1500);
    } catch {
      // Fallback
      const ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      els.copyBtn.textContent = getText(getLanguage(), 'price.btn.copied');
      setTimeout(() => { els.copyBtn.textContent = getText(getLanguage(), 'price.btn.copy'); }, 1500);
    }
  });

  // Reset
  els.resetBtn.addEventListener('click', () => {
    els.workType.value = 'headshot';
    els.doujinPages.value = '1';
    els.wantCover.checked = false;
    els.coverScale.value = 'headshot';
    (document.querySelector<HTMLInputElement>('input[name="calc-color"][value="color"]'))!.checked = true;
    els.characters.value = '1';
    els.complexity.value = 'normal';
    els.background.value = 'none';
    els.rush.value = 'normal';
    els.commercial.checked = false;
    els.live2d.checked = false;
    els.adult.checked = false;
    els.adultConfirm.checked = false;
    els.rigging.checked = false;
    els.sourceFile.checked = false;
    els.extraParts.value = '0';
    els.deposit.dataset.currency = 'th';
    els.deposit.value = '300';
    els.notes.value = '';
    els.projectTitle.value = 'Commission artwork';
    els.clientName.value = '';
    render();
  });

  window.addEventListener('languageChanged', render);

  // Initial render
  render();
</script>

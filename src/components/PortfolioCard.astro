---
import type { PortfolioItem } from '../data/portfolio';

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
---

<button
  type="button"
  class:list={[
    'portfolio-card group block w-full text-left rounded-xl border border-line bg-white overflow-hidden transition-all hover:shadow-lg hover:border-primary/20 break-inside-avoid mb-4',
    item.isAdult && 'is-adult',
    item.isBlurred && 'is-blurred',
  ]}
  data-item-id={item.id}
  data-is-adult={item.isAdult.toString()}
  data-title={item.title}
  data-image={item.image}
  data-gallery={encodeURIComponent(JSON.stringify(item.galleryImages ?? [item.coverImage ?? item.image]))}
  data-description={item.description}
>
  <!-- Image -->
  <div class="relative overflow-hidden bg-secondary-light">
    <img
      src={item.image}
      alt={item.isAdult ? 'เนื้อหาสำหรับผู้ใหญ่ (18+)' : item.title}
      class:list={[
        'w-full aspect-[3/4] transition-transform duration-300 group-hover:scale-[1.02]',
        item.allowCrop ? 'object-cover' : 'object-contain',
        item.isBlurred && 'adult-blur',
      ]}
      loading="lazy"
      onerror={`this.onerror=null;this.src='${item.isAdult || item.isBlurred ? '/images/portfolio/portfolio-r18-placeholder.png' : '/images/portfolio/portfolio-placeholder.png'}';`}
    />
    {(item.isAdult || item.isBlurred) && (
      <div class="absolute inset-0 z-10 flex flex-col items-center justify-center bg-black/40 text-white opacity-100 group-hover:opacity-0 transition-opacity duration-300 pointer-events-none">
        <div class="text-4xl mb-2">🔞</div>
        <span class="font-bold px-3 py-1 bg-black/60 rounded-full text-sm backdrop-blur-md" data-i18n="portfolio.adult.badge">18+ Preview</span>
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-4">
    <h3 class="font-bold text-ink text-base mb-1">{item.title}</h3>
    <p class="text-sm text-muted leading-relaxed">{item.description}</p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      {item.category.map((cat) => (
        <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-secondary-light text-primary/70 border border-secondary-dark/20">
          {cat === 'adult' ? '18+ NSFW' : cat}
        </span>
      ))}
    </div>
  </div>
</button>

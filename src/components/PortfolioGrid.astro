---
import PortfolioCard from './PortfolioCard.astro';
import { portfolio, portfolioFilters, type PortfolioItem } from '../data/portfolio';

interface Props {
  /** Only show SFW items (for homepage) */
  sfwOnly?: boolean;
  /** Limit the number of items shown */
  limit?: number;
  /** Use fixed responsive grid layout for homepage featured items */
  featured?: boolean;
}

const { sfwOnly = false, limit, featured = false } = Astro.props;

let items: PortfolioItem[] = sfwOnly
  ? portfolio.filter((item) => !item.isAdult && !item.isBlurred && item.canShow)
  : portfolio.filter((item) => item.canShow);

if (limit) {
  items = items.slice(0, limit);
}

const showFilters = !sfwOnly;
---

{showFilters && (
  <div class="flex flex-wrap gap-2 mb-6" id="portfolio-filters" role="toolbar" aria-label="กรองผลงาน">
    {portfolioFilters.map((filter) => (
      <button
        type="button"
        class:list={[
          'filter-btn px-4 py-2 rounded-full text-sm font-semibold border transition-all',
          filter.id === 'all'
            ? 'bg-secondary text-primary border-primary/20'
            : 'bg-white text-muted border-line hover:text-primary hover:bg-secondary-light hover:border-primary/20',
        ]}
        data-filter={filter.id}
        data-i18n={`portfolio.filter.${filter.id}`}
      >
        {filter.label}
      </button>
    ))}
  </div>
)}

<div
  class:list={[
    featured
      ? 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 [&_.portfolio-card]:mb-0'
      : 'columns-1 sm:columns-2 lg:columns-3 gap-4 [&_.portfolio-card]:mb-0',
  ]}
  id="portfolio-grid"
>
  {items.map((item) => (
    <div
      class:list={[
        'portfolio-item',
        !featured && 'mb-4 break-inside-avoid',
      ]}
      data-categories={JSON.stringify(item.category)}
      data-is-adult={item.isAdult.toString()}
      data-is-blurred={item.isBlurred?.toString()}
    >
      <PortfolioCard item={item} />
    </div>
  ))}
</div>

<!-- Lightbox -->
<div
  id="portfolio-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm"
  aria-hidden="true"
>
  <div class="relative w-full max-w-4xl max-h-[90vh] bg-white rounded-2xl overflow-hidden shadow-2xl flex flex-col">
    <div class="flex items-center justify-between px-4 py-3 border-b border-line">
      <h3 id="lightbox-title" class="font-bold text-ink truncate">Preview</h3>
      <div class="flex items-center gap-4">
        <span id="lightbox-counter" class="text-sm font-semibold text-muted hidden">1 / 1</span>
        <button
          type="button"
          id="lightbox-close"
          class="w-9 h-9 rounded-lg border border-line bg-white hover:bg-secondary-light text-muted hover:text-primary transition-colors grid place-items-center"
          aria-label="ปิด"
        >
          ✕
        </button>
      </div>
    </div>
    <div class="flex-1 relative overflow-auto bg-secondary-light flex items-center justify-center p-4 group/lightbox">
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-w-full max-h-[75vh] object-contain rounded-lg"
      />
      <button
        type="button"
        id="lightbox-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-primary transition-colors hidden opacity-0 group-hover/lightbox:opacity-100 focus:opacity-100"
        aria-label="Previous"
      >
        ❮
      </button>
      <button
        type="button"
        id="lightbox-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-primary transition-colors hidden opacity-0 group-hover/lightbox:opacity-100 focus:opacity-100"
        aria-label="Next"
      >
        ❯
      </button>
    </div>
  </div>
</div>

<script>
  // ─── Portfolio Filtering ───
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.portfolio-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach((b) => {
        b.classList.remove('bg-secondary', 'text-primary', 'border-primary/20');
        b.classList.add('bg-white', 'text-muted', 'border-line');
      });
      btn.classList.remove('bg-white', 'text-muted', 'border-line');
      btn.classList.add('bg-secondary', 'text-primary', 'border-primary/20');

      items.forEach((item) => {
        const categories: string[] = JSON.parse(item.dataset.categories || '[]');
        const isAdult = item.dataset.isAdult === 'true';
        const isBlurred = item.dataset.isBlurred === 'true';

        if (filter === 'all') {
          item.style.display = '';
        } else if (filter === 'sfw') {
          item.style.display = (isAdult || isBlurred) ? 'none' : '';
        } else if (filter === 'adult') {
          item.style.display = (isAdult || isBlurred) ? '' : 'none';
        } else {
          item.style.display = categories.includes(filter!) ? '' : 'none';
        }
      });
    });
  });

  // ─── Lightbox ───
  const lightbox = document.getElementById('portfolio-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');

  let currentGallery: string[] = [];
  let currentIndex = 0;
  let currentIsAdult = false;
  let currentTitle = '';

  function updateLightboxImage() {
    if (!lightboxImg) return;
    const src = currentGallery[currentIndex];
    lightboxImg.src = src;
    lightboxImg.alt = currentTitle;
    lightboxImg.onerror = () => {
      lightboxImg.onerror = null;
      lightboxImg.src = currentIsAdult ? '/images/portfolio/portfolio-r18-placeholder.png' : '/images/portfolio/portfolio-placeholder.png';
    };

    if (currentGallery.length > 1) {
      if (lightboxCounter) {
        lightboxCounter.textContent = `${currentIndex + 1} / ${currentGallery.length}`;
        lightboxCounter.classList.remove('hidden');
      }
      if (lightboxPrev) lightboxPrev.classList.remove('hidden');
      if (lightboxNext) lightboxNext.classList.remove('hidden');
    } else {
      if (lightboxCounter) lightboxCounter.classList.add('hidden');
      if (lightboxPrev) lightboxPrev.classList.add('hidden');
      if (lightboxNext) lightboxNext.classList.add('hidden');
    }
  }

  function openLightbox(title: string, images: string[], isAdultOrBlurred: boolean = false) {
    if (!lightbox || !lightboxImg || !lightboxTitle) return;
    
    currentGallery = images;
    currentIndex = 0;
    currentIsAdult = isAdultOrBlurred;
    currentTitle = title;
    
    lightboxTitle.textContent = title;
    updateLightboxImage();

    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    lightbox.setAttribute('aria-hidden', 'false');
  }

  function closeLightbox() {
    if (!lightbox || !lightboxImg) return;
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImg.src = '';
  }

  function nextImage() {
    if (currentGallery.length <= 1) return;
    currentIndex = (currentIndex + 1) % currentGallery.length;
    updateLightboxImage();
  }

  function prevImage() {
    if (currentGallery.length <= 1) return;
    currentIndex = (currentIndex - 1 + currentGallery.length) % currentGallery.length;
    updateLightboxImage();
  }

  lightboxPrev?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  lightboxNext?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

  // Age gate check stored in sessionStorage
  function hasAgeConfirmation(): boolean {
    return sessionStorage.getItem('gosofia-age-confirmed') === 'true';
  }

  function setAgeConfirmation() {
    sessionStorage.setItem('gosofia-age-confirmed', 'true');
  }

  document.querySelectorAll<HTMLButtonElement>('.portfolio-card').forEach((card) => {
    card.addEventListener('click', () => {
      const isAdult = card.dataset.isAdult === 'true';
      const isBlurred = card.dataset.isBlurred === 'true';
      const title = card.dataset.title || 'Preview';
      
      let gallery: string[] = [];
      try {
        if (card.dataset.gallery) {
           gallery = JSON.parse(decodeURIComponent(card.dataset.gallery));
        } else if (card.dataset.image) {
           gallery = [card.dataset.image];
        }
      } catch (e) {
        gallery = [card.dataset.image || ''];
      }

      if (isAdult || isBlurred) {
        if (!hasAgeConfirmation()) {
          // Show age gate
          const ageGate = document.getElementById('age-gate-modal');
          if (ageGate) {
            ageGate.classList.remove('hidden');
            ageGate.classList.add('flex');
            ageGate.dataset.pendingTitle = title;
            ageGate.dataset.pendingGallery = encodeURIComponent(JSON.stringify(gallery));
            ageGate.dataset.pendingAdult = (isAdult || isBlurred).toString();
          }
          return;
        }
      }

      openLightbox(title, gallery, isAdult || isBlurred);
    });
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });

  // Age gate confirm handler
  const ageGateConfirm = document.getElementById('age-gate-confirm');
  const ageGateCancel = document.getElementById('age-gate-cancel');
  const ageGateModal = document.getElementById('age-gate-modal');

  ageGateConfirm?.addEventListener('click', () => {
    setAgeConfirmation();
    if (ageGateModal) {
      const title = ageGateModal.dataset.pendingTitle || '';
      const galleryStr = ageGateModal.dataset.pendingGallery || '';
      const isAdult = ageGateModal.dataset.pendingAdult === 'true';
      ageGateModal.classList.add('hidden');
      ageGateModal.classList.remove('flex');
      
      let gallery: string[] = [];
      try {
        if (galleryStr) gallery = JSON.parse(decodeURIComponent(galleryStr));
      } catch (e) {}

      if (title && gallery.length > 0) openLightbox(title, gallery, isAdult);
    }
  });

  ageGateCancel?.addEventListener('click', () => {
    if (ageGateModal) {
      ageGateModal.classList.add('hidden');
      ageGateModal.classList.remove('flex');
    }
  });
</script>

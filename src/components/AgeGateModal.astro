---
// Age Gate Modal — renders as hidden, shown via client-side JS
---

<div
  id="age-gate-modal"
  class="fixed inset-0 z-[60] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="age-gate-title"
>
  <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden">
    <!-- Header -->
    <div class="px-6 py-4 bg-gradient-to-r from-primary to-primary-light">
      <h2 id="age-gate-title" class="text-lg font-bold text-white" data-i18n="agegate.title">⚠️ ยืนยันอายุ</h2>
    </div>

    <!-- Body -->
    <div class="px-6 py-5">
      <div class="text-center">
        <div class="text-5xl mb-4">🔞</div>
        <h3 class="text-2xl font-extrabold text-ink mb-2" data-i18n="agegate.title">⚠️ ยืนยันอายุ</h3>
        <p class="text-muted mb-6">
          <span data-i18n="agegate.desc1">เนื้อหาต่อไปนี้สำหรับผู้ที่มีอายุ 18 ปีขึ้นไปเท่านั้น</span><br/>
          <span class="text-sm" data-i18n="agegate.desc2">หากคุณยืนยันว่ามีอายุ 18 ปีขึ้นไป กดปุ่ม "ยืนยัน" เพื่อดูเนื้อหา การยืนยันนี้จะมีผลในเซสชันปัจจุบันเท่านั้น</span>
        </p>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-3">
        <button id="age-gate-cancel" class="flex-1 px-4 py-3 rounded-xl border border-line text-muted font-bold hover:bg-surface transition-colors" data-i18n="agegate.cancel">
          ย้อนกลับ
        </button>
        <button id="age-gate-confirm" class="flex-1 px-4 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary-light transition-colors" data-i18n="agegate.confirm">
          ยืนยัน — ฉันอายุ 18+
        </button>
      </div>
    </div>
  </div>
</div>

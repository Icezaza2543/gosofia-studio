---
import { navigation } from '../data/navigation';
import { artist } from '../data/artist';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-line">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-3 group" id="site-logo">
        <img
          src="/images/brand/logo-gosofia.png"
          alt="Gosofia"
          width="40"
          height="40"
          class="w-10 h-10 rounded-lg bg-white object-contain shadow-md group-hover:scale-105 transition-transform"
        />
        <div class="hidden sm:block">
          <span class="text-lg font-bold text-primary">{artist.name}</span>
          {artist.commissionStatus === 'open' && (
            <span class="ml-2 text-xs font-bold px-2 py-0.5 rounded-full bg-green-100 text-green-700 border border-green-200">
              Commission Open
            </span>
          )}
        </div>
      </a>

      <!-- Desktop Navigation & Lang Toggle -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="เมนูหลัก" data-i18n="nav.label">
        {navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-semibold transition-colors',
              currentPath === item.href
                ? 'bg-secondary text-primary'
                : 'text-muted hover:text-primary hover:bg-secondary-light',
            ]}
            data-i18n={`nav.${item.href}`}
          >
            {item.label}
          </a>
        ))}
        
        <div class="ml-4 flex items-center bg-secondary-light rounded-lg p-1">
          <button type="button" class="lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors bg-white text-primary shadow-sm" data-lang="th">TH</button>
          <button type="button" class="lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors text-muted hover:text-primary" data-lang="en">EN</button>
        </div>
      </nav>

      <div class="lg:hidden flex items-center gap-2">
        <div class="flex items-center bg-secondary-light rounded-lg p-1">
          <button type="button" class="lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors bg-white text-primary shadow-sm" data-lang="th">TH</button>
          <button type="button" class="lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors text-muted hover:text-primary" data-lang="en">EN</button>
        </div>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="w-10 h-10 rounded-lg border border-line bg-white grid place-items-center text-muted hover:text-primary transition-colors"
          aria-label="เปิดเมนู"
          aria-expanded="false"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-menu"
    class="hidden lg:hidden border-t border-line bg-white/95 backdrop-blur-lg"
    aria-label="เมนูมือถือ"
    data-i18n="nav.label"
  >
    <div class="max-w-6xl mx-auto px-4 py-3 grid gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-3 rounded-lg text-sm font-semibold transition-colors',
            currentPath === item.href
              ? 'bg-secondary text-primary'
              : 'text-muted hover:text-primary hover:bg-secondary-light',
          ]}
          data-i18n={`nav.${item.href}`}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  import { i18n, type Language } from '../data/i18n';

  // ─── Language Controller ───
  function setLanguage(lang: Language) {
    localStorage.setItem('gosofia-lang', lang);
    document.documentElement.lang = lang;
    
    // Update active state of buttons
    document.querySelectorAll('.lang-btn').forEach((btn) => {
      const btnLang = btn.getAttribute('data-lang');
      const isMobile = btn.classList.contains('flex-1'); // quick check for mobile vs desktop style
      
      if (btnLang === lang) {
        if (isMobile) {
          btn.className = 'lang-btn flex-1 py-2 rounded-lg text-sm font-bold transition-colors bg-secondary text-primary border border-primary/20';
        } else {
          btn.className = 'lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors bg-white text-primary shadow-sm';
        }
      } else {
        if (isMobile) {
          btn.className = 'lang-btn flex-1 py-2 rounded-lg text-sm font-bold transition-colors bg-white text-muted border border-line';
        } else {
          btn.className = 'lang-btn px-2.5 py-1 rounded-md text-xs font-bold transition-colors text-muted hover:text-primary';
        }
      }
    });

    // Translate DOM elements
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && i18n[lang][key as keyof typeof i18n.th]) {
        const val = i18n[lang][key as keyof typeof i18n.th];
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          if (el.hasAttribute('placeholder')) {
            el.setAttribute('placeholder', val);
          }
        } else if (el.hasAttribute('data-i18n-html')) {
           el.innerHTML = val;
        } else {
           // For elements with mixed content (like span with nested span), we only want to change the direct text node if possible,
           // but replacing innerHTML is easiest. Wait, if we use textContent, we lose child nodes.
           // That's why we should put data-i18n on the exact leaf node (e.g. span).
           el.textContent = val;
        }
      }
    });

    document.querySelectorAll('[data-i18n-title]').forEach((el) => {
      const key = el.getAttribute('data-i18n-title');
      if (key && i18n[lang][key as keyof typeof i18n.th]) {
        el.setAttribute('title', i18n[lang][key as keyof typeof i18n.th]);
      }
    });

    document.querySelectorAll('[data-i18n-aria-label]').forEach((el) => {
      const key = el.getAttribute('data-i18n-aria-label');
      if (key && i18n[lang][key as keyof typeof i18n.th]) {
        el.setAttribute('aria-label', i18n[lang][key as keyof typeof i18n.th]);
      }
    });
    
    // Dispatch event so other scripts (like calculator) can react
    window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang } }));
  }

  // Initialize
  const savedLang = (localStorage.getItem('gosofia-lang') as Language) || 'th';
  setLanguage(savedLang);

  document.querySelectorAll('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang') as Language;
      if (lang) setLanguage(lang);
    });
  });

  // ─── Mobile Menu ───

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
